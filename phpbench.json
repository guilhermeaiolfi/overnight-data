{
    "runner.bootstrap": "vendor/autoload.php",
    "runner.path": "benchmarks",
    "runner.retry_threshold": 10,
    "storage.xml_storage_path": "benchmark/results/storage",
    "report.generators": {
        "default": {
            "generator": "expression",
            "title": "Aggregate by Subject",
            "description": "Aggregate results by subject and group by benchmark class.",
            "break": [
                "benchmark"
            ],
            "expressions": {
                "name": "if(first(variant_name) != \"\", first(subject_name) ~ \" (\" ~ first(variant_name) ~ \")\", first(subject_name))",
                "_mode": "mode(result_time_avg)"
            },
            "cols": [
                "name",
                "revs",
                "its",
                "mode",
                "rstdev",
                "mem_peak"
            ],
            "derivations": {
                "mode": "display_as_time(row[\"_mode\"], coalesce(row[\"time_unit\"], \"time\"), row[\"time_precision\"], row[\"time_mode\"])",
                "mem_peak": "row[\"mem_peak\"] as memory",
                "rstdev": "row[\"rstdev\"] as \"rstdev\""
            }
        },
        "baseline-summary": {
            "generator": "expression",
            "title": "Aggregate by Subject",
            "description": "Aggregate results by subject and group by benchmark class.",
            "break": [
                "benchmark"
            ],
            "expressions": {
                "name": "if(first(variant_name) != \"\", first(subject_name) ~ \" (\" ~ first(variant_name) ~ \")\", first(subject_name))",
                "_mode": "mode(result_time_avg)"
            },
            "cols": [
                "name",
                "revs",
                "its",
                "mem_peak",
                "mode",
                "rstdev",
                "diff"
            ],
            "derivations": {
                "diff": "if(min(table[\"_mode\"]) > 0, format(\"%.2fx\", row[\"_mode\"] / min(table[\"_mode\"])), \"N/A\")",
                "mode": "display_as_time(row[\"_mode\"], coalesce(row[\"time_unit\"], \"time\"), row[\"time_precision\"], row[\"time_mode\"])",
                "mem_peak": "row[\"mem_peak\"] as memory",
                "rstdev": "row[\"rstdev\"] as \"rstdev\""
            }
        }
    }
}
