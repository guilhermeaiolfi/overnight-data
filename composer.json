{
    "name": "guilhermeaiolfi/overnight-data",
    "description": "The definition foundation of a metadata-driven PHP data layer.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "metadata",
        "definitions",
        "data-layer"
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "ON\\Data\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\ON\\Data\\": "tests/"
        }
    },
    "scripts": {
        "validate-composer": "composer validate --strict",
        "test": "vendor/bin/phpunit --configuration phpunit.xml.dist",
        "analyse": "vendor/bin/phpstan analyse --configuration phpstan.neon.dist",
        "check-style": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff",
        "fix-style": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php",
        "check": [
            "@test",
            "@analyse",
            "@check-style"
        ]
    }
}
