{
    "name": "guilhermeaiolfi/overnight-data",
    "description": "A metadata-driven PHP data layer with definitions, mapping, query modeling, relation loading, and ORM persistence.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "metadata",
        "definitions",
        "data-layer"
    ],
    "require": {
        "php": ">=8.3",
        "cycle/database": "^2.16"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^1.12",
        "phpbench/phpbench": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "ON\\Data\\": "src/"
        },
        "files": [
            "src/Mapper/functions.php",
            "src/Query/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\ON\\Data\\": "tests/",
            "Benchmarks\\ON\\Data\\": "benchmarks/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.1.x-dev"
        }
    },
    "scripts": {
        "validate-composer": "composer validate --strict",
        "test": "php vendor/phpunit/phpunit/phpunit --configuration phpunit.xml.dist",
        "analyse": "php vendor/phpstan/phpstan/phpstan analyse --configuration phpstan.neon.dist",
        "check-style": "php vendor/friendsofphp/php-cs-fixer/php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff",
        "fix-style": "php vendor/friendsofphp/php-cs-fixer/php-cs-fixer fix --config=.php-cs-fixer.php",
        "bench": "php vendor/phpbench/phpbench/bin/phpbench run --config=phpbench.json",
        "bench:mapping": "php vendor/phpbench/phpbench/bin/phpbench run --config=phpbench.json --filter=MappingBench",
        "bench:mapping:record": "php benchmark/mapping_bench.php record",
        "bench:mapping:compare": "php benchmark/mapping_bench.php compare",
        "bench:mapping:history": "php benchmark/mapping_bench.php history",
        "check": [
            "@test",
            "@analyse",
            "@check-style"
        ]
    }
}
