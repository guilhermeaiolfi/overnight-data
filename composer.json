{
    "name": "guilhermeaiolfi/overnight-data",
    "description": "The definition foundation of a metadata-driven PHP data layer.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "metadata",
        "definitions",
        "data-layer"
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^1.12",
        "phpbench/phpbench": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "ON\\Data\\": "src/"
        },
        "files": [
            "src/Mapper/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\ON\\Data\\": "tests/",
            "Benchmarks\\ON\\Data\\": "benchmarks/"
        }
    },
    "scripts": {
        "validate-composer": "composer validate --strict",
        "test": "vendor/bin/phpunit --configuration phpunit.xml.dist",
        "analyse": "vendor/bin/phpstan analyse --configuration phpstan.neon.dist",
        "check-style": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff",
        "fix-style": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php",
        "bench": "phpbench run --config=phpbench.json",
        "bench:mapping": "phpbench run --config=phpbench.json --filter=MappingBench",
        "bench:mapping:record": "php benchmark/mapping_bench.php record",
        "bench:mapping:compare": "php benchmark/mapping_bench.php compare",
        "bench:mapping:history": "php benchmark/mapping_bench.php history",
        "check": [
            "@test",
            "@analyse",
            "@check-style"
        ]
    }
}
